# AWS Cognito public SPA configuration. These identifiers are safe for the
# browser; never add a Cognito app client secret to a VITE_ variable.
VITE_AWS_COGNITO_USER_POOL_ID=us-west-2_REPLACE_ME
VITE_AWS_COGNITO_USER_POOL_CLIENT_ID=REPLACE_ME

# Server-side integrations only. Do not prefix secrets with VITE_.
POMERIUM_ZERO_TOKEN=
ZERO_API_KEY=
