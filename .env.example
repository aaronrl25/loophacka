POMERIUM_ISSUER=https://app.looper.example.com
POMERIUM_AUDIENCE=https://app.looper.example.com
POMERIUM_JWKS_URL=https://app.looper.example.com/.well-known/pomerium/jwks.json
DATABASE_URL=postgres://looper:replace-me@postgres.internal:5432/looper
AUDIT_RETENTION_DAYS=2555
APP_ENV=development

# The installed Zero runner authenticates with `zero auth login`; it does not
# consume these HTTP credentials. They remain blank until Zero documents an
# HTTP deployment contract for your environment.
ZERO_API_KEY=
ZERO_BASE_URL=
ZERO_RUNNER=zero
ZERO_MAX_EXECUTION_COST_USD=1
ZERO_DAILY_USER_BUDGET_USD=5
ZERO_DAILY_ORG_BUDGET_USD=25
ZERO_APPROVAL_THRESHOLD_USD=0.25
