# Public identifiers only. Keep the app client secret in a secret manager or
# Docker secret and mount it at /run/secrets/cognito_app_client_secret.
AWS_REGION=us-west-2
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=

# Pomerium Zero enrollment token. Never commit a real token.
POMERIUM_ZERO_TOKEN=
